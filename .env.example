# Langfuse Configuration
# Get these from https://cloud.langfuse.com (or your self-hosted instance)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com or https://us.cloud.langfuse.com or https://your-langfuse-instance.com or http://localhost:3000

# For US region, use:
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# For self-hosted:
# LANGFUSE_HOST=https://your-langfuse-instance.com

# Optional: MCP Server Configuration
MCP_SERVER_PORT=3000
LOG_LEVEL=INFO
CACHE_ENABLED=true

# Optional: Alert Thresholds
COST_ALERT_THRESHOLD_USD=100
LATENCY_ALERT_THRESHOLD_MS=5000
ERROR_RATE_ALERT_THRESHOLD=0.05
